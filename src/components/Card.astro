---
interface Props {
  title: string;
  href: string;
  description?: string;
}

const { title, href, description } = Astro.props;
---

<a href={href} class="block p-4 bg-white border border-gray-200 rounded-lg hover:shadow-md transition-shadow">
  <h3 class="text-lg font-semibold text-gray-900 mb-1">{title}</h3>
  {description && <p class="text-sm text-gray-600">{description}</p>}
</a>
