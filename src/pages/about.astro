---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About - Crafty Prash">
  <div class="about-page">
    <h1>About</h1>
    <div class="content">
      <p>
        I'm CraftyPrash on the internet or just Prashant, and I am a passionate software creator and technical writer. I love building systems that are performant and beautiful from the inside. Here I will be sharing my knowledge through detailed technical guides and articles.
      </p>
      <p>
        With extensive experience in software development and system architecture, I focus on creating content that helps developers understand complex concepts and implement best practices.
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    max-width: 720px;
    margin: 0 auto;
  }

  .about-page h1 {
    font-size: 3rem;
    margin-bottom: 2rem;
  }

  .content p {
    font-size: 1.0625rem;
    color: var(--text-primary);
    line-height: 1.65;
    margin: 1.5em 0;
  }
</style>
