---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides');

// Group by guide name and get first chapter of each
const guideMap = new Map();
guides.forEach(guide => {
  const guideName = guide.data.guide || guide.slug;
  if (!guideMap.has(guideName) || (guide.data.chapter || 0) < (guideMap.get(guideName).data.chapter || 0)) {
    guideMap.set(guideName, guide);
  }
});

const uniqueGuides = Array.from(guideMap.values()).sort((a, b) => 
  b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Guides - Crafty Prash">
  <div class="guides-page">
    <h1>Guides</h1>
    <p class="subtitle">Comprehensive tutorials and documentation</p>
    
    <div class="cards">
      {uniqueGuides.map(guide => (
        <Card 
          title="Sample Guide"
          href={`/guides/${guide.slug}`}
          description="A comprehensive guide with multiple chapters"
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .guides-page {
    max-width: 800px;
    margin: 0 auto;
  }

  .guides-page h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 3rem;
  }

  .cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
