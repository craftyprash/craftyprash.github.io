---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
---

<BaseLayout title="Crafty Prash">
  <div class="home-page">
    <div class="hero">
      <h1>Welcome</h1>
      <p>Quick notes and comprehensive guides</p>
    </div>
    
    <div class="sections">
      <section>
        <h2>Notes</h2>
        <div class="cards">
          <Card 
            title="Sample Note" 
            href="/notes/sample"
            description="A quick one-pager note"
          />
        </div>
      </section>

      <section>
        <h2>Guides</h2>
        <div class="cards">
          <Card 
            title="Sample Guide" 
            href="/guides/sample"
            description="A comprehensive guide with chapters"
          />
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .home-page {
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero {
    margin-bottom: 4rem;
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.25rem;
    color: var(--text-secondary);
  }

  .sections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 3rem;
  }

  .sections h2 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    border-bottom: none;
  }

  .cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2rem;
    }

    .sections {
      grid-template-columns: 1fr;
    }
  }
</style>
