---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import brandLogo from '../assets/brand-logo.png';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="description" content="Personal site with notes and guides" />
  <title>{title}</title>
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="preload" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css" as="style" />
  <script is:inline>
    (function() {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css';
      document.head.appendChild(link);
    })();
  </script>
</head>
<body>
  <header class="top-bar">
    <div class="container">
      <a href="/" class="logo">
        <img src={brandLogo.src} alt="CraftyPrash" />
        <span>CraftyPrash</span>
      </a>
      <nav class="nav">
        <a href="/notes" class:list={['nav-link', { active: currentPath.includes('/notes') }]}>
          <i class="ph ph-file-text"></i>
          <span>Notes</span>
        </a>
        <a href="/guides" class:list={['nav-link', { active: currentPath.includes('/guides') }]}>
          <i class="ph ph-book-open"></i>
          <span>Guides</span>
        </a>
        <a href="/about" class:list={['nav-link', { active: currentPath.includes('/about') }]}>
          <i class="ph ph-user"></i>
          <span>About</span>
        </a>
        <a href="https://github.com/craftyprash" target="_blank" rel="noopener" class="nav-link">
          <i class="ph ph-github-logo"></i>
        </a>
      </nav>
    </div>
  </header>
  <main class="main-content">
    <slot />
  </main>
  <Footer />
</body>
</html>

<style>
  .top-bar {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1;
  }

  .logo img {
    width: 48px;
    height: 36px;
    border-radius: 6px;
    display: block;
    margin: 0;
  }

  .nav {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    transition: color 0.2s;
    line-height: 1;
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link.active {
    color: var(--accent);
  }

  .main-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    min-height: calc(100vh - 200px);
  }

  @media (max-width: 768px) {
    .container {
      padding: 1rem;
    }

    .logo span {
      display: none;
    }

    .nav {
      gap: 1rem;
    }

    .nav-link span {
      display: none;
    }

    .main-content {
      padding: 2rem 1rem;
    }
  }
</style>
