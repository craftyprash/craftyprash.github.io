---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ShareButtons from '../components/ShareButtons.astro';
import Giscus from '../components/Giscus.astro';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
}

const { title, description, date, tags = [] } = Astro.props;
const formattedDate = date?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const publishedTime = date?.toISOString();
---

<BaseLayout title={title} description={description} type="article" publishedTime={publishedTime}>
  <article class="note-layout">
    <div class="author-meta">
      <a href="/about">
        <img src="/images/prashant.jpg" alt="Prashant P" class="author-avatar" />
      </a>
      <div class="author-name">Prashant P</div>
    </div>
    
    {date && (
      <div class="date-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
    )}
    
    <div class="prose">
      <slot />
    </div>
    
    <div class="content-footer">
      <ShareButtons title={title} />
      <Giscus />
    </div>
  </article>
</BaseLayout>

<style>
  .note-layout {
    max-width: 65ch;
    margin: 0 auto;
  }

  .author-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    margin: 0;
  }

  .author-name {
    font-weight: 500;
    color: var(--text-primary);
  }

  .date-meta {
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .date-meta time {
    font-size: 1rem;
    color: var(--text-secondary);
  }

  .prose :global(h1:first-child) {
    margin-top: 0;
    text-align: center;
  }

  .prose {
    font-size: 1.125rem;
  }

  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol) {
    line-height: 1.6;
  }

  .content-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }


</style>
