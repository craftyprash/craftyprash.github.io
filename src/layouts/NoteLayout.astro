---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ShareButtons from '../components/ShareButtons.astro';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
}

const { title, description, date, tags = [] } = Astro.props;
const formattedDate = date?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title}>
  <article class="note-layout">
    <div class="content-body">
      <header class="content-header">
        <h1>{title}</h1>
        {(date || tags.length > 0) && (
          <div class="meta">
            {date && <time datetime={date.toISOString()}>{formattedDate}</time>}
            {tags.length > 0 && (
              <div class="tags">
                {tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
            )}
          </div>
        )}
      </header>
      
      <div class="prose">
        <slot />
      </div>
      
      <div class="content-footer">
        <ShareButtons title={title} />
      </div>
    </div>
    
    <aside class="toc-sidebar">
      <TableOfContents />
    </aside>
  </article>
</BaseLayout>

<style>
  .note-layout {
    display: grid;
    grid-template-columns: 1fr 200px;
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .content-header h1 {
    margin-top: 0;
  }

  .meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--bg-tertiary);
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .content-body {
    grid-column: 1;
    min-width: 0;
  }

  .prose {
    max-width: 100%;
  }

  .content-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .toc-sidebar {
    grid-column: 2;
    position: sticky;
    top: 5rem;
    height: fit-content;
  }

  @media (max-width: 1024px) {
    .note-layout {
      grid-template-columns: 1fr;
    }

    .toc-sidebar {
      display: none;
    }
  }
</style>
