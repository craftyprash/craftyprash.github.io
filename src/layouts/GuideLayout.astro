---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ShareButtons from '../components/ShareButtons.astro';
import Giscus from '../components/Giscus.astro';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  chapters?: Array<{ slug: string; title: string }>;
  currentSlug?: string;
}

const { title, date, tags = [], chapters = [], currentSlug } = Astro.props;
const formattedDate = date?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

let prevChapter = null;
let nextChapter = null;

if (currentSlug && chapters.length > 0) {
  const currentIndex = chapters.findIndex(ch => ch.slug === currentSlug);
  if (currentIndex > 0) {
    prevChapter = chapters[currentIndex - 1];
  }
  if (currentIndex < chapters.length - 1) {
    nextChapter = chapters[currentIndex + 1];
  }
}
---

<BaseLayout title={title}>
  <div class="guide-layout">
    {chapters.length > 0 && (
      <aside class="sidebar">
        <h3>Chapters</h3>
        <nav>
          {chapters.map(chapter => (
            <a 
              href={`/guides/${chapter.slug}`}
              class:list={['chapter-link', { active: chapter.slug === currentSlug }]}
            >
              {chapter.title}
            </a>
          ))}
        </nav>
      </aside>
    )}

    <article class="content">
      <header>
        <h1>{title}</h1>
        {(date || tags.length > 0) && (
          <div class="meta">
            {date && <time datetime={date.toISOString()}>{formattedDate}</time>}
            {tags.length > 0 && (
              <div class="tags">
                {tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
            )}
          </div>
        )}
        <ShareButtons title={title} />
      </header>

      <div class="prose">
        <slot />
      </div>

      {(prevChapter || nextChapter) && (
        <nav class="pagination">
          {prevChapter && (
            <a href={`/guides/${prevChapter.slug}`} class="prev">
              <span class="label">← Previous</span>
              <span class="title">{prevChapter.title}</span>
            </a>
          )}
          {nextChapter && (
            <a href={`/guides/${nextChapter.slug}`} class="next">
              <span class="label">Next →</span>
              <span class="title">{nextChapter.title}</span>
            </a>
          )}
        </nav>
      )}

      <div class="footer">
        <Giscus />
      </div>
    </article>

    <aside class="toc">
      <TableOfContents />
    </aside>
  </div>
</BaseLayout>

<style>
  .guide-layout {
    display: grid;
    grid-template-columns: 180px minmax(0, 720px) 200px;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .sidebar {
    position: sticky;
    top: 5rem;
    height: fit-content;
  }

  .sidebar h3 {
    font-size: 0.9rem;
    margin: 0 0 1rem 0;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .sidebar nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .chapter-link {
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    color: var(--text-secondary);
    transition: all 0.2s;
    font-size: 0.875rem;
  }

  .chapter-link:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }

  .chapter-link.active {
    background: var(--bg-tertiary);
    color: var(--accent);
    font-weight: 500;
  }

  .content {
    grid-column: 2;
    min-width: 0;
  }

  .content h1 {
    margin-top: 0;
  }

  .meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--bg-tertiary);
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .prose {
    font-size: 1.125rem;
  }

  .pagination {
    display: flex;
    justify-content: space-between;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    gap: 2rem;
  }

  .pagination a {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: all 0.2s;
    flex: 1;
  }

  .pagination a:hover {
    border-color: var(--accent);
  }

  .pagination .prev {
    align-items: flex-start;
  }

  .pagination .next {
    align-items: flex-end;
    margin-left: auto;
  }

  .pagination .label {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .pagination .title {
    font-weight: 500;
    color: var(--text-primary);
  }

  .toc {
    grid-column: 3;
    position: sticky;
    top: 5rem;
    height: fit-content;
  }

  @media (max-width: 1024px) {
    .guide-layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: relative;
      top: 0;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--border);
    }

    .content {
      grid-column: 1;
    }

    .toc {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .pagination {
      flex-direction: column;
    }

    .pagination .next {
      margin-left: 0;
    }
  }
</style>
